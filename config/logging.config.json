{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "standard": {
      "format": "%(asctime)s [%(levelname)s] %(name)s: %(message)s"
    },
    "json": {
      "format": "%(asctime)s %(levelname)s %(name)s %(message)s",
      "class": "pythonjsonlogger.jsonlogger.JsonFormatter"
    }
  },
  "handlers": {
    "console": {
      "class": "logging.StreamHandler",
      "level": "INFO",
      "formatter": "standard",
      "stream": "ext://sys.stdout"
    },
    "file": {
      "class": "logging.handlers.RotatingFileHandler",
      "level": "DEBUG",
      "formatter": "json",
      "filename": "/var/log/tinkerflow/app.log",
      "maxBytes": 10485760,
      "backupCount": 5
    }
  },
  "loggers": {
    "": {
      "handlers": ["console", "file"],
      "level": "INFO"
    },
    "gateway": {
      "level": "DEBUG",
      "propagate": false,
      "handlers": ["console", "file"]
    },
    "app": {
      "level": "DEBUG",
      "propagate": false,
      "handlers": ["console", "file"]
    }
  }
}
