
`json
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Richard Kindler Supporter Schema",
  "description": "Defines supporters, tiers, and metadata for personal sponsor recognition.",
  "type": "object",
  "properties": {
    "supporters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "username": { "type": "string" },
          "tier": {
            "type": "string",
            "enum": [
              "community",
              "developer",
              "infrastructure",
              "ecosystem",
              "institutional"
            ]
          },
          "amount": { "type": "number" },
          "platform": {
            "type": "string",
            "enum": ["github", "buymeacoffee", "custom"]
          },
          "since": { "type": "string", "format": "date" }
        },
        "required": ["username", "tier", "platform"]
      }
    }
  },
  "required": ["supporters"]
}
`